{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["matter-js"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../src/shared/*"],
      "@client/*": ["../src/client/*"]
    }
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
